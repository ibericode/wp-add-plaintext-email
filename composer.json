{
    "name": "dannyvankooten/wp-add-plaintext-email",
    "type": "wordpress-plugin",
    "description": "WordPress plugin to automatically generate a plaintext version of HTML emails sent with wp_mail",
    "keywords": ["wordpress","cdn"],
    "homepage": "https://git.sr.ht/~dvko/wp-add-plaintext-email",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Danny van Kooten",
            "homepage": "http://dvk.co"
        }
    ],
    "require": {
        "php": ">=5.2.0"
    },
    "scripts": {
        "check-syntax": "find . -name '*.php' -not -path './vendor/*' -not -path './node_modules/*' -not -path './assets/*' -print0 | xargs -0 -n1 php -l"
    }
}
